def lightControlMeterDelayMsValue() {
    if (lightControlDisableMetering == true) return 0
    def ms = lightControlMeterDelayMs
    if (ms == null) return 75
    try {
        ms = ms.toInteger()
    } catch (e) {
        ms = 75
    }
    return Math.max(0, Math.min(2000, ms))
}

